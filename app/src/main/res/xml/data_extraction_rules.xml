<?xml version="1.0" encoding="utf-8"?>
<!--
   Data extraction rules for Android 12+.
   Controls cloud backup and device-to-device transfer.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="taskflow_database" />
        <include domain="sharedpref" path="." />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="taskflow_database" />
        <include domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>
