<?xml version="1.0" encoding="utf-8"?>
<!--
   Quick Add Task Bottom Sheet Layout
   Minimal interface for rapid task creation.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/surface"
    android:orientation="vertical"
    android:padding="@dimen/spacing_lg">

    <!-- Drag Handle -->
    <View
        android:layout_width="@dimen/bottom_sheet_handle_width"
        android:layout_height="@dimen/bottom_sheet_handle_height"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="@dimen/spacing_lg"
        android:background="@drawable/bg_bottom_sheet_handle"/>

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/quick_add_title"
        android:textAppearance="@style/TextAppearance.TaskFlow.Title.Large"
        android:textColor="@color/text_primary"/>

    <!-- Task Title Input -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/input_layout_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_lg"
        style="@style/Widget.TaskFlow.TextInputLayout">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edit_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/quick_add_placeholder"
            android:imeOptions="actionDone"
            android:inputType="text"
            android:maxLines="1"/>

    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md"
        android:text="@string/task_category_label"
        android:textAppearance="@style/TextAppearance.TaskFlow.Label.Medium"
        android:textColor="@color/text_secondary"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_category_selector"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm"
        android:clickable="true"
        android:focusable="true"
        app:cardBackgroundColor="@color/surface_container"
        app:cardCornerRadius="@dimen/radius_sm"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/spacing_md">

            <TextView
                android:id="@+id/text_category_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textAppearance="@style/TextAppearance.TaskFlow.Body.Small"
                android:textColor="@color/text_primary"
                tools:text="General"/>

            <ImageView
                android:layout_width="@dimen/icon_sm"
                android:layout_height="@dimen/icon_sm"
                android:src="@drawable/ic_expand_more"
                android:contentDescription="@null"/>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Quick Options Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_lg"
        android:orientation="horizontal">

        <!-- Board Selector -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_board_selector"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/spacing_sm"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/surface_container"
            app:cardCornerRadius="@dimen/radius_sm"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_md">

                <ImageView
                    android:layout_width="@dimen/icon_md"
                    android:layout_height="@dimen/icon_md"
                    android:src="@drawable/ic_board"
                    android:tint="@color/text_secondary"
                    android:contentDescription="@null"/>

                <TextView
                    android:id="@+id/text_board_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_sm"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textAppearance="@style/TextAppearance.TaskFlow.Body.Small"
                    android:textColor="@color/text_primary"
                    tools:text="Product Launch"/>

                <ImageView
                    android:layout_width="@dimen/icon_sm"
                    android:layout_height="@dimen/icon_sm"
                    android:src="@drawable/ic_expand_more"
                    android:contentDescription="@null"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Column Selector -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_column_selector"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_sm"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/surface_container"
            app:cardCornerRadius="@dimen/radius_sm"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_md">

                <View
                    android:id="@+id/view_column_color"
                    android:layout_width="4dp"
                    android:layout_height="@dimen/icon_md"
                    android:background="@drawable/bg_chip"
                    tools:backgroundTint="@color/status_todo"/>

                <TextView
                    android:id="@+id/text_column_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_sm"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textAppearance="@style/TextAppearance.TaskFlow.Body.Small"
                    android:textColor="@color/text_primary"
                    tools:text="To Do"/>

                <ImageView
                    android:layout_width="@dimen/icon_sm"
                    android:layout_height="@dimen/icon_sm"
                    android:src="@drawable/ic_expand_more"
                    android:contentDescription="@null"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- Due Date Quick Options -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_lg"
        android:text="@string/task_due_date"
        android:textAppearance="@style/TextAppearance.TaskFlow.Label.Medium"
        android:textColor="@color/text_secondary"/>

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chip_group_due_date"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm"
        app:singleSelection="true">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_due_today"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/quick_add_due_today"
            style="@style/Widget.TaskFlow.Chip.Filter"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_due_tomorrow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/quick_add_due_tomorrow"
            style="@style/Widget.TaskFlow.Chip.Filter"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_due_next_week"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/quick_add_due_next_week"
            style="@style/Widget.TaskFlow.Chip.Filter"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_due_custom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/task_due_date_hint"
            app:chipIcon="@drawable/ic_calendar"
            app:chipIconTint="@color/text_secondary"
            style="@style/Widget.TaskFlow.Chip"/>

    </com.google.android.material.chip.ChipGroup>

    <!-- Actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xl"
        android:gravity="end"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_more_options"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/spacing_sm"
            android:text="@string/quick_add_more_options"
            style="@style/Widget.TaskFlow.Button.Text"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_add_task"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/action_add"
            style="@style/Widget.TaskFlow.Button"/>

    </LinearLayout>

</LinearLayout>
