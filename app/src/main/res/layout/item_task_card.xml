<?xml version="1.0" encoding="utf-8"?>
<!--
   Task Card Layout for Kanban Board
   Displays task summary with priority, tags, assignee, and progress.
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/card_task"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_sm"
    android:clickable="true"
    android:focusable="true"
    android:longClickable="true"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="@dimen/radius_md"
    app:cardElevation="@dimen/elevation_sm"
    app:rippleColor="@color/ripple_light"
    style="@style/Widget.TaskFlow.Card.Task">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md">

        <!-- Top Row: Priority and Drag Handle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Priority Chip -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_priority"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/chip_height_small"
                android:textAppearance="@style/TextAppearance.TaskFlow.Label.Small"
                android:visibility="gone"
                app:chipCornerRadius="@dimen/radius_xs"
                app:chipMinHeight="@dimen/chip_height_small"
                tools:text="Urgent"
                tools:visibility="visible"/>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <!-- Drag Handle (shown during drag mode) -->
            <ImageView
                android:id="@+id/drag_handle"
                android:layout_width="@dimen/icon_lg"
                android:layout_height="@dimen/icon_lg"
                android:src="@drawable/ic_drag_handle"
                android:contentDescription="@string/a11y_drag_handle"
                android:visibility="invisible"/>

        </LinearLayout>

        <!-- Task Title -->
        <TextView
            android:id="@+id/text_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:ellipsize="end"
            android:maxLines="2"
            android:textAppearance="@style/TextAppearance.TaskFlow.Body.Medium"
            android:textColor="@color/text_primary"
            tools:text="Fix login crash on Android 14"/>

        <!-- Description Preview -->
        <TextView
            android:id="@+id/text_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:ellipsize="end"
            android:maxLines="2"
            android:textAppearance="@style/TextAppearance.TaskFlow.Body.Small"
            android:textColor="@color/text_secondary"
            android:visibility="gone"
            tools:text="App crashes when biometric prompt is cancelled"
            tools:visibility="visible"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_category"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/chip_height_small"
            android:layout_marginTop="@dimen/spacing_xs"
            android:textAppearance="@style/TextAppearance.TaskFlow.Label.Small"
            android:visibility="gone"
            app:chipBackgroundColor="@color/surface_variant"
            app:chipCornerRadius="@dimen/radius_xs"
            app:chipMinHeight="@dimen/chip_height_small"
            tools:text="Work"
            tools:visibility="visible"/>

        <!-- Tags -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_tags"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:visibility="gone"
            app:chipSpacingHorizontal="@dimen/spacing_xs"
            app:chipSpacingVertical="@dimen/spacing_xs"
            app:singleLine="true"
            tools:visibility="visible">

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="@dimen/chip_height_small"
                android:text="Bug"
                android:textAppearance="@style/TextAppearance.TaskFlow.Label.Small"
                android:textColor="@color/tag_red"
                app:chipBackgroundColor="@color/tag_red_bg"
                app:chipCornerRadius="@dimen/radius_xs"
                app:chipMinHeight="@dimen/chip_height_small"/>

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="@dimen/chip_height_small"
                android:text="Urgent"
                android:textAppearance="@style/TextAppearance.TaskFlow.Label.Small"
                android:textColor="@color/tag_orange"
                app:chipBackgroundColor="@color/tag_orange_bg"
                app:chipCornerRadius="@dimen/radius_xs"
                app:chipMinHeight="@dimen/chip_height_small"/>

        </com.google.android.material.chip.ChipGroup>

        <!-- Progress Bar -->
        <LinearLayout
            android:id="@+id/progress_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone"
            tools:visibility="visible">

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progress_bar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:progress="60"
                app:indicatorColor="@color/progress_indicator"
                app:trackColor="@color/progress_track"
                app:trackCornerRadius="@dimen/radius_xs"
                app:trackThickness="@dimen/progress_bar_height"
                style="@style/Widget.TaskFlow.ProgressIndicator.Linear"/>

            <TextView
                android:id="@+id/text_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_sm"
                android:textAppearance="@style/TextAppearance.TaskFlow.Label.Small"
                android:textColor="@color/text_tertiary"
                tools:text="60%"/>

        </LinearLayout>

        <!-- Bottom Row: Due Date and Assignee -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Due Date -->
            <LinearLayout
                android:id="@+id/due_date_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone"
                tools:visibility="visible">

                <ImageView
                    android:layout_width="@dimen/icon_sm"
                    android:layout_height="@dimen/icon_sm"
                    android:src="@drawable/ic_calendar"
                    android:tint="@color/text_tertiary"
                    android:contentDescription="@null"/>

                <TextView
                    android:id="@+id/text_due_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_xxs"
                    android:textAppearance="@style/TextAppearance.TaskFlow.Label.Small"
                    android:textColor="@color/text_tertiary"
                    tools:text="Tomorrow"/>

            </LinearLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <!-- Assignee Avatar -->
            <FrameLayout
                android:id="@+id/assignee_container"
                android:layout_width="@dimen/avatar_sm"
                android:layout_height="@dimen/avatar_sm"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/text_assignee_initials"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_avatar"
                    android:backgroundTint="@color/avatar_1"
                    android:gravity="center"
                    android:textAppearance="@style/TextAppearance.TaskFlow.Label.Small"
                    android:textColor="@color/text_inverse"
                    tools:text="AC"/>

            </FrameLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
